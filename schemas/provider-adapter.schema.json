{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlas-ai.no/schemas/provider-adapter.schema.json",
  "title": "NTSN Orchestrator Provider Adapter Contract Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "adapterId",
    "provider",
    "releaseTrain",
    "runtimeClass",
    "readCapabilities",
    "planCapabilities",
    "writeCapabilities",
    "approvalRequiredForWrite",
    "dryRunSupported",
    "auditRequired",
    "forbiddenActionCategories",
    "evidenceSources",
    "fallbackOnUnknown",
    "executionAllowedByDefault"
  ],
  "properties": {
    "adapterId": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "releaseTrain": { "type": "string", "const": "O-RT6" },
    "runtimeClass": {
      "type": "string",
      "enum": [
        "READ_ONLY_READY",
        "PLAN_ONLY_READY",
        "CONTROLLED_WRITE_PENDING_APPROVAL",
        "NOT_CONFIGURED",
        "PENDING_REVIEW"
      ]
    },
    "readCapabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "planCapabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "writeCapabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "approvalRequiredForWrite": { "type": "boolean", "const": true },
    "dryRunSupported": { "type": "boolean" },
    "auditRequired": { "type": "boolean", "const": true },
    "forbiddenActionCategories": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "evidenceSources": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "fallbackOnUnknown": {
      "type": "string",
      "enum": ["NOT_CONFIGURED", "PENDING_REVIEW"]
    },
    "executionAllowedByDefault": { "type": "boolean", "const": false }
  }
}
